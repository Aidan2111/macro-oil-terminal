{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "routes": [
    {
      "route": "/api/*",
      "rewrite": "https://REPLACE_ME_oil-tracker-api-canadaeast-NNNN.azurewebsites.net/api/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/build-info.txt",
      "headers": { "Cache-Control": "no-store" }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/_next/*", "/static/*", "/*.{png,jpg,gif,ico,css,js,svg,txt}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
