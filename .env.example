# Copy to .env for local dev. DO NOT commit real keys.
# On Azure App Service, these are set as App Settings and inherit into os.environ.

# --- Azure OpenAI (Trade Thesis / AI Insights) ---
AZURE_OPENAI_ENDPOINT=https://oil-tracker-aoai.openai.azure.com/
AZURE_OPENAI_KEY=replace-me
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# --- Real-time AIS feed (optional, flips Tab 3 to live websocket) ---
# Free key from https://aisstream.io/apikeys  — GitHub signin, no credit card.
# Without this, the dashboard shows a labeled Q3 2024 historical snapshot.
# AISSTREAM_API_KEY=replace-me

# --- Inventory fallback (optional, used if EIA dnav is down) ---
# Free key from https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=replace-me

# --- Future pricing upgrade (optional) ---
# 800 free calls/day; 8/min. https://twelvedata.com/pricing
# TWELVEDATA_API_KEY=replace-me

# --- Email alerts (optional) ---
# ALERT_SMTP_HOST=smtp.example.com
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=you@example.com
# ALERT_SMTP_PASS=replace-me
# ALERT_SMTP_FROM=you@example.com
# ALERT_SMTP_TO=you@example.com
